# Cloud Run / local — set via console or `gcloud run deploy --set-env-vars`
PORT=8080
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
ENCRYPTED_TOKEN_CONTRACT_ID=
ADMIN_PUBLIC_KEY=
CORS_ORIGIN=https://your-shield-frontend.example.com
VK_BUILD_DIR=/app/circuits/build
# RAPIDSNARK_BIN=/usr/local/bin/prover

# View key recovery (testnet demo — stores BabyJub sk server-side on register)
PERSIST_REGISTER_STATE=true
# Local fallback when GCS bucket is not set:
REGISTER_STATE_DIR=./data/register-states
# Production (Cloud Run): persist in GCS — run run/setup-gcs-register-bucket.ps1 first
GCS_REGISTER_STATE_BUCKET=
GCS_REGISTER_STATE_PREFIX=register-states
